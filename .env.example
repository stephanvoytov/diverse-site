# ===== SMTP (обязательно — основной канал заявок) =====
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@yandex.ru
SMTP_PASS=your-password
MAIL_TO=manager@example.com

# ===== Telegram Bot (обязательно — второй канал заявок) =====
# Получить: @BotFather → /newbot → токен
# Chat ID: https://api.telegram.org/bot<TOKEN>/getUpdates → найти "chat":{"id":...}
# Можно указать несколько через запятую: 123,456
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# ===== Dadata (опционально — определение города по IP) =====
# Получить: https://dadata.ru/api/#api-key (бесплатно 10 000 запросов/мес)
DADATA_API_KEY=

# ===== Публичные (видны на клиенте) =====
NEXT_PUBLIC_BASE_PATH=
NEXT_PUBLIC_YM_ID=
NEXT_PUBLIC_FORM_ENDPOINT=/api/lead
